# Supabase — required for writing candidates to the DB
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: JSON array of scrape sources (overrides built-in defaults)
# Example:
# SCRAPE_SOURCES_JSON='[{"id":"ig-bekarobar","platform":"instagram","handle":"bekarobar","url":"https://www.instagram.com/bekarobar/","language_hint":"mixed","priority":"high","fetch_mode":"public_text"}]'
SCRAPE_SOURCES_JSON=

# Optional: comma-separated source IDs to run (blank = all active sources)
INGEST_SOURCE_IDS=

# Optional: max candidates to insert per run (default 50)
INGEST_MAX_CANDIDATES=50

# Optional: dry run — extract candidates but don't write to DB (true/false)
INGEST_DRY_RUN=false
